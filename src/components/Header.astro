---
import LotterySelector from './LotterySelector.astro';
import DateNav from './DateNav.astro';

export interface Props {
  pageSlug: string;
}

const { pageSlug } = Astro.props;
---

<header
  class="fixed top-0 left-0 w-full z-50 bg-gradient-to-br from-bg via-surface to-[#0F0F1E] border-b border-accent/20 backdrop-blur-md"
  style="box-shadow: 0 8px 32px rgba(0, 217, 255, 0.08)"
>
  <div class="max-w-grid mx-auto flex flex-col md:flex-row items-center justify-between gap-3 md:gap-5 px-4 py-3 md:px-8 md:py-4">
    <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-r from-accent to-accent-alt rounded-xl blur opacity-50"></div>
        <div class="relative bg-surface-2 px-4 py-2 rounded-xl">
          <span class="text-lg md:text-xl font-bold bg-gradient-to-r from-accent via-accent-alt to-accent bg-clip-text text-transparent">
            LOTERIA<span class="text-accent">.ai</span>
          </span>
        </div>
      </div>
    </a>

    <div class="flex flex-row items-center justify-center gap-3 w-full md:w-auto md:gap-4">
      <LotterySelector pageSlug={pageSlug} />
      <DateNav pageSlug={pageSlug} />
    </div>
  </div>
</header>

<style>
  header {
    --header-h: 80px;
  }
  @media (min-width: 768px) {
    header {
      --header-h: 100px;
    }
  }
</style>
