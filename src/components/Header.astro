---
import LotterySelector from './LotterySelector.astro';
import DateNav from './DateNav.astro';

export interface Props {
  pageSlug: string;
}

const { pageSlug } = Astro.props;
---

<header
  class="fixed top-0 left-0 w-full z-50 glass border-b border-accent/10"
  style="box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);"
>
  <div class="max-w-grid mx-auto flex items-center justify-between gap-3 px-4 py-3 md:px-6 md:py-4">
    <a href="/" class="flex items-center gap-2.5 group" aria-label="LoteriaBR - Início">
      <div class="relative flex items-center justify-center w-9 h-9 rounded-xl bg-gradient-to-br from-accent via-violet to-pink overflow-hidden">
        <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5 text-white relative z-10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/>
          <path d="M2 17l10 5 10-5"/>
          <path d="M2 12l10 5 10-5"/>
        </svg>
        <div class="absolute inset-0 bg-gradient-to-br from-accent via-violet to-pink opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </div>
      <span class="font-display text-lg font-bold tracking-tight">
        <span class="text-text-primary">Loteria</span><span class="gradient-text">BR</span>
      </span>
    </a>

    <div class="flex flex-row items-center gap-2 md:gap-3">
      <LotterySelector pageSlug={pageSlug} />
      <DateNav pageSlug={pageSlug} />
    </div>
  </div>
</header>
