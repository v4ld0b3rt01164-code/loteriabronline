---
import LotterySelector from './LotterySelector.astro';
import DateNav from './DateNav.astro';

export interface Props {
  pageSlug: string;
}

const { pageSlug } = Astro.props;
---

<header
  class="fixed top-0 left-0 w-full z-50 glass border-b border-accent/10"
  style="box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);"
>
  <div class="max-w-grid mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-4 md:gap-3 px-4 py-4 md:px-6 md:py-3">
    <a href="/" class="flex items-center justify-center md:justify-start group" aria-label="LoteriaBR - Início">
      <img src="/logo.webp" alt="LoteriaBR" class="h-[78px] md:h-[100px] w-auto object-contain" fetchpriority="high" />
    </a>

    <div class="flex flex-row items-center justify-center gap-1.5 md:gap-3">
      <LotterySelector pageSlug={pageSlug} />
      <DateNav pageSlug={pageSlug} />
    </div>
  </div>
</header>
