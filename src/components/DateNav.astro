---
export interface Props {
  pageSlug: string;
}

const { pageSlug } = Astro.props;
---

<div
  data-page-slug={pageSlug}
  id="dateNav"
  class="flex items-center bg-surface-2/40 border border-accent/40 rounded-lg w-auto max-w-[240px] md:max-w-[300px] min-h-[40px] overflow-hidden backdrop-blur-sm hover:border-accent/60 transition-all"
>
  <button id="prevDate" class="flex items-center justify-center w-10 h-full bg-accent/10 text-accent hover:bg-accent/20 transition-all shrink-0 border-r border-accent/20 focus-visible:ring-2 focus-visible:ring-accent focus-visible:outline-none" aria-label="Data anterior">
    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <input
    type="date"
    id="inputData"
    class="flex-1 bg-transparent text-accent px-2 py-2 font-sans font-bold text-center cursor-pointer text-[0.9rem] md:text-[0.95rem] leading-tight outline-none focus-visible:ring-2 focus-visible:ring-accent/50 focus-visible:ring-inset"
    aria-label="Selecionar data"
  />
  <button id="nextDate" class="flex items-center justify-center w-10 h-full bg-accent/10 text-accent hover:bg-accent/20 transition-all shrink-0 border-l border-accent/20 focus-visible:ring-2 focus-visible:ring-accent focus-visible:outline-none" aria-label="Próxima data">
    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
</div>

<script>
  import {
    API_URL,
    FILTROS,
    ANIMAIS,
  } from '../lib/constants';
  import {
    getDataInteligente,
    formatarDataBR,
    nomeExibicao,
    type ApiResponse,
    type LoteriaResultado,
  } from '../lib/utils';

  const dateNav = document.getElementById('dateNav')!;
  const pageSlug = dateNav.getAttribute('data-page-slug') || 'index';

  const inputData = document.getElementById('inputData') as HTMLInputElement;
  const resultContainer = document.getElementById('resultContainer')!;
  const emptyState = document.getElementById('emptyState')!;
  const loadingState = document.getElementById('loadingState')!;

  const filterList = FILTROS[pageSlug] || FILTROS['index'];
  const isBA = pageSlug === 'bahia';

  inputData.value =
    new URLSearchParams(window.location.search).get('data') ||
    getDataInteligente();

  async function carregarResultados() {
    const data = inputData.value;
    loadingState.classList.remove('hidden');
    loadingState.textContent = 'Carregando...';
    resultContainer.innerHTML = '';
    emptyState.classList.add('hidden');

    try {
      const res = await fetch(`${API_URL}?data=${data}`);
      if (!res.ok) throw new Error('network');
      const json: ApiResponse = await res.json();

      if (!json.loterias || !json.loterias.length) {
        throw new Error('empty');
      }

      const filtradas = json.loterias.filter((l) => {
        const nome = l.nome_loteria.split(' - ')[0];
        return filterList.includes(nome);
      });

      if (filtradas.length === 0) {
        throw new Error('empty');
      }

      filtradas.sort((a, b) => {
        const reg = /(\d{1,2}):(\d{2})/;
        const m1 = a.nome_loteria.match(reg);
        const m2 = b.nome_loteria.match(reg);
        if (!m1 || !m2) return 0;
        return (
          parseInt(m1[1], 10) * 60 + parseInt(m1[2], 10) -
          (parseInt(m2[1], 10) * 60 + parseInt(m2[2], 10))
        );
      });

      emptyStateMsg('Nenhum resultado disponível para esta data.');
      renderizarCards(filtradas, data);
    } catch (err) {
      loadingState.classList.add('hidden');
      const msg = (err as Error).message;
      if (msg === 'network') {
        emptyStateMsg('Erro ao carregar resultados. Tente novamente.');
      } else {
        emptyStateMsg('Nenhum resultado disponível para esta data.');
      }
      emptyState.classList.remove('hidden');
    }
  }

  function emptyStateMsg(texto: string) {
    const p = emptyState.querySelector('p');
    if (p) p.textContent = texto;
  }

  function renderizarCards(lista: LoteriaResultado[], dataAtual: string) {
    loadingState.classList.add('hidden');
    resultContainer.innerHTML = '';

    if (lista.length === 0) {
      emptyState.classList.remove('hidden');
      return;
    }

    const dataFormatada = formatarDataBR(dataAtual);

    for (const loteria of lista) {
      const resultadosExibir = isBA
        ? loteria.resultados.slice(0, 5)
        : loteria.resultados;
      const primeiro = resultadosExibir[0] || { milhar: '----', grupo: 0 };
      const animal = ANIMAIS[primeiro.grupo] || 'Desconhecido';
      const exibicao = nomeExibicao(loteria.nome_loteria);

      const idx = Array.from(resultContainer.children).length;
      const isPar = idx % 2 === 0;
      const tituloBg = isPar
        ? 'bg-gradient-to-r from-accent to-accent-alt text-bg'
        : 'bg-gradient-to-r from-accent-alt to-accent text-bg';

      const card = document.createElement('div');
      card.className = 'result-card';

      card.innerHTML = `
        <div class="rounded-xl overflow-hidden border border-accent/20 hover:border-accent/50 transition-all">
          <div class="titulo-bar text-center text-sm md:text-base font-extrabold uppercase py-3 px-2 tracking-wider ${tituloBg}"></div>
          <div class="p-4 md:p-5 flex flex-col gap-4 bg-gradient-to-br from-surface to-surface-2">
            <div class="flex items-center justify-between">
              <div class="flex flex-col min-w-0">
                <span class="text-xs opacity-70 uppercase font-semibold text-text-secondary">1º Prêmio</span>
                <span class="premio-valor text-2xl md:text-3xl font-black tracking-wider text-accent"></span>
              </div>
              <div class="flex flex-col items-center gap-2 shrink-0">
                <span class="animal-nome text-xs font-bold text-accent text-center"></span>
                <img class="animal-img w-14 h-14 md:w-16 md:h-16 object-contain drop-shadow-lg" loading="lazy" alt="">
              </div>
            </div>
            <table class="w-full text-xs">
              <tbody class="table-body divide-y divide-accent/10"></tbody>
            </table>
            <button class="share-btn w-full bg-gradient-to-r from-accent via-accent-alt to-accent text-bg font-bold py-2.5 rounded-lg hover:shadow-lg hover:shadow-accent/30 transition-all transform hover:-translate-y-0.5 flex items-center justify-center gap-2">
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Compartilhar
            </button>
          </div>
        </div>
      `;

      card.querySelector('.titulo-bar')!.textContent = exibicao;
      (card.querySelector('.premio-valor')!).textContent = primeiro.milhar;
      const img = card.querySelector('.animal-img') as HTMLImageElement;
      img.src = `/animais-webp/${primeiro.grupo}.webp`;
      img.alt = animal;
      card.querySelector('.animal-nome')!.textContent = animal;

      const tbody = card.querySelector('.table-body')!;
      for (const r of resultadosExibir) {
        const tr = document.createElement('tr');
        tr.className = 'py-2 flex justify-between items-center';

        const td1 = document.createElement('td');
        td1.className = 'text-text-secondary font-medium';
        td1.textContent = r.posicao;

        const td2 = document.createElement('td');
        td2.className = 'font-bold text-accent text-center flex-1 mx-2';
        td2.textContent = r.milhar;

        const td3 = document.createElement('td');
        td3.className = 'text-text-secondary font-medium text-right';
        td3.textContent = r.grupo > 0 ? String(r.grupo) : '-';

        tr.appendChild(td1);
        tr.appendChild(td2);
        tr.appendChild(td3);
        tbody.appendChild(tr);
      }

      const resultadosTexto = resultadosExibir
        .map((r) => '• ' + r.posicao + ': ' + r.milhar + ' - ' + (ANIMAIS[r.grupo] || ''))
        .join('\n');
      card.setAttribute('data-texto-zap',
        `*${exibicao}* - *${dataFormatada}*\n*Resultados:*\n${resultadosTexto}\n\n*loteriabr.online*`);

      resultContainer.appendChild(card);
    }
  }

  resultContainer.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest('.share-btn');
    if (!btn) return;
    const cardEl = btn.closest('[data-texto-zap]') as HTMLElement;
    if (!cardEl) return;
    window.open(
      `https://wa.me/?text=${encodeURIComponent(cardEl.getAttribute('data-texto-zap') || '')}`,
      '_blank'
    );
  });

  function mudarData(delta: number) {
    const d = new Date(inputData.value + 'T12:00:00');
    d.setDate(d.getDate() + delta);
    const ano = d.getFullYear();
    const mes = String(d.getMonth() + 1).padStart(2, '0');
    const dia = String(d.getDate()).padStart(2, '0');
    inputData.value = `${ano}-${mes}-${dia}`;
    const params = new URLSearchParams(window.location.search);
    params.set('data', inputData.value);
    window.history.replaceState(
      {},
      '',
      `${window.location.pathname}?${params.toString()}`
    );
    carregarResultados();
  }

  document.getElementById('prevDate')!.addEventListener('click', () => mudarData(-1));
  document.getElementById('nextDate')!.addEventListener('click', () => mudarData(1));

  inputData.addEventListener('change', () => {
    const params = new URLSearchParams(window.location.search);
    params.set('data', inputData.value);
    window.history.replaceState(
      {},
      '',
      `${window.location.pathname}?${params.toString()}`
    );
    carregarResultados();
  });

  carregarResultados();

  setInterval(() => {
    if (!document.hidden) carregarResultados();
  }, 15 * 60 * 1000);
</script>
