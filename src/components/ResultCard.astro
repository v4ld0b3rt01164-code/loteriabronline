---
export interface Props {
  exibicao: string;
  dataAtual: string;
  primeiroMilhar: string;
  primeiroGrupo: number;
  animalNome: string;
  resultados: Array<{ posicao: string; milhar: string; grupo: number }>;
  isPar: boolean;
  idx: number;
  shareUrl: string;
}

const {
  exibicao,
  dataAtual,
  primeiroMilhar,
  primeiroGrupo,
  animalNome,
  resultados,
  isPar,
  idx,
  shareUrl,
} = Astro.props;

const tituloGradient = isPar
  ? 'background: linear-gradient(135deg, #6366F1, #8B5CF6);'
  : 'background: linear-gradient(135deg, #8B5CF6, #EC4899);';
---

<article
  class="result-card"
  style={`animation-delay: ${idx * 0.06}s;`}
  data-texto-zap={Astro.props['data-texto-zap']}
>
  <div
    class="text-center text-sm md:text-base font-extrabold uppercase py-3 px-3 tracking-wider text-white whitespace-nowrap overflow-hidden text-ellipsis"
    style={tituloGradient}
  >
    <h3 class="inline">{exibicao}</h3>
  </div>

  <div class="p-3 md:p-5 flex flex-col gap-3">
    <div class="flex items-center justify-between gap-2">
      <div class="flex flex-col min-w-0">
        <span class="text-[13px] md:text-xs uppercase font-semibold text-text-muted tracking-wider">
          1º Prêmio
        </span>
        <span class="text-[26px] md:text-3xl font-black tracking-wider gradient-text">
          {primeiroMilhar}
        </span>
      </div>

      <div class="flex flex-col items-center gap-1 shrink-0">
        <span class="text-xs md:text-sm font-bold text-accent-light text-center leading-tight">
          {animalNome}
        </span>
        <img
          class="w-14 h-14 md:w-18 md:h-18 object-contain drop-shadow-[0_4px_8px_rgba(0,0,0,0.4)]"
          loading="lazy"
          decoding="async"
          width="56"
          height="56"
          src={`/animais-webp/${primeiroGrupo}.webp`}
          alt={animalNome}
        />
      </div>
    </div>

    <table class="w-full text-[15px] md:text-base border-collapse" aria-label={`Resultados de ${exibicao}`}>
      <caption class="sr-only">{`Resultados completos de ${exibicao} em ${dataAtual}`}</caption>
      <thead class="hidden md:table-header-group">
        <tr class="border-b border-white/20">
          <th class="text-text-muted text-xs uppercase font-semibold tracking-wider py-2 px-2 text-left">Posição</th>
          <th class="text-text-muted text-xs uppercase font-semibold tracking-wider py-2 px-1 text-center">Milhar</th>
          <th class="text-text-muted text-xs uppercase font-semibold tracking-wider py-2 px-2 text-right">Grupo</th>
        </tr>
      </thead>
      <tbody>
        {resultados.map((r, i) => (
          <tr
            class="border-b border-white/20"
            style={i % 2 === 0 ? 'background: rgba(148, 163, 184, 0.04);' : undefined}
          >
            <td class="text-text-secondary font-medium py-3 px-2 w-[35%]">{r.posicao}</td>
            <td class="font-bold text-accent-light text-center py-3 px-1 w-[30%]">{r.milhar}</td>
            <td class="text-text-secondary font-medium text-right py-3 px-2 w-[35%]">
              {r.grupo > 0 ? String(r.grupo) : '-'}
            </td>
          </tr>
        ))}
      </tbody>
    </table>

    <a
      href={shareUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="share-btn w-full bg-gradient-to-r from-accent/10 via-violet/10 to-pink/10 border border-accent/15 text-accent-light font-semibold py-2.5 rounded-xl hover:border-accent/30 hover:from-accent/15 hover:via-violet/15 hover:to-pink/15 transition-all duration-300 flex items-center justify-center gap-2 text-sm md:text-base no-underline"
      aria-label={`Compartilhar resultados de ${exibicao} no WhatsApp`}
    >
      <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Compartilhar
    </a>
  </div>
</article>
