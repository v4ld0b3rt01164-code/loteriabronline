---
export interface Props {
  currentPage: string;
}

const { currentPage } = Astro.props;
---

<footer
  class="fixed bottom-0 left-0 w-full z-50 glass border-t border-accent/10"
  style="height: var(--footer-h);"
>
  <div class="h-full flex items-center justify-center">
    <div class="flex flex-col sm:flex-row items-center gap-1 sm:gap-4 px-4">
      <nav class="flex items-center gap-1 text-sm md:text-base">
        <a href="/contato" class="text-text-secondary hover:text-accent-light transition-colors px-2 py-1">Contato</a>
        <span class="text-text-muted/30">|</span>
        <a href="/politica-de-privacidade" class="text-text-secondary hover:text-accent-light transition-colors px-2 py-1">Privacidade</a>
        <span class="text-text-muted/30">|</span>
        <a href="/termos-de-uso" class="text-text-secondary hover:text-accent-light transition-colors px-2 py-1">Termos</a>
      </nav>
      <p class="text-text-muted text-xs md:text-sm">
        &copy; <span id="year"></span> LoteriaBR
      </p>
    </div>
  </div>
</footer>
