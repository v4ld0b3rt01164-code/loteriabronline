---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import DateNav from '../components/DateNav.astro';

export interface Props {
  title: string;
  description: string;
  currentPage: string;
  pageSlug: string;
}

const { title, description, currentPage, pageSlug } = Astro.props;
---

<BaseLayout title={title} description={description} currentPage={currentPage}>
  <Fragment slot="header">
    <Header pageSlug={pageSlug} />
  </Fragment>

  <div class="px-2">
    <div class="max-w-grid mx-auto mb-2 mt-2 md:mb-4 md:mt-4">
      <div id="resultContainer" class="card-grid"></div>
      <div id="emptyState" class="hidden text-center py-12 text-text-secondary">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-accent/5 border border-accent/10 mb-4">
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
        <p class="text-base">Nenhum resultado disponível para esta data.</p>
      </div>
      <div id="loadingState" class="hidden text-accent-light py-10 text-center font-semibold text-base tracking-wide">
        <div class="inline-flex items-center gap-3">
          <div class="w-5 h-5 border-2 border-accent/30 border-t-accent rounded-full animate-spin"></div>
          Carregando resultados...
        </div>
      </div>
    </div>
    <slot />
  </div>
</BaseLayout>
