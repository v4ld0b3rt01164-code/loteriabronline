---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Página não encontrada - LoteriaBR"
  description="Página não encontrada"
  currentPage="404"
>
  <main class="flex-1 flex flex-col items-center justify-center px-4 text-center" style="padding-top: var(--header-h); padding-bottom: var(--footer-h);">
    <h1 class="text-6xl font-black text-accent mb-4">404</h1>
    <p class="text-text-secondary text-lg mb-8">Página não encontrada.</p>
    <a href="/" class="btn-voltar">
      <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
      Voltar ao início
    </a>
  </main>
</BaseLayout>
